<link rel="stylesheet" href="$content.getURI('scripts/lib/bootstrap/css/bootstrap.min.css')">

<style>
    .dashboard-edit-form {
        width: 100%;
    }

    .dashboard-edit-form .form-control {
        padding: 6px 12px;
    }

    /* Override bootstrap and stick to xnat style */
    .panel-default .panel-heading {
        padding: 12px 16px;
        color: #fff;
        background: #1A75BB;
    }

    .panel-title {
        font-size: 18px;
    }

    .panel-default .panel-body {
        padding: 30px 15%;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-description {
        margin-top: 5px;
    }

</style>

<style>
    .dashboard-manager {
        width: 100%;
        margin: 0 auto;
        padding: 0 5%;
    }

    .dashboard-manager .heading {
        display: flex;
        flex-direction: row;
        justify-content: flex-start;
        align-items: center;
        margin: 0 0 20px 0;
    }

    .dashboard-manager .footer {
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
        align-items: center;
        margin: 20px 0;
    }

</style>

<div id="dashboard-manager" class="dashboard-manager">
    <div class="heading">
        <h3 class="title">Manage Dashboards</h3>
    </div>

    <div class="body">
    </div>

    <div class="footer">
        <button type="button" class="btn btn-primary btn-sm pull-right"
                onclick="XNAT.plugin.jupyterhub.dashboards.editor({}, 'new')">Create Dashboard</button>
    </div>
</div>

<script type="text/javascript">

    var XNAT = getObject(XNAT || {});
    XNAT.plugin = getObject(XNAT.plugin || {});
    XNAT.plugin.jupyterhub = jupyterhub = getObject(XNAT.plugin.jupyterhub || {});
    XNAT.plugin.jupyterhub.dashboards = dashboards = getObject(XNAT.plugin.jupyterhub.dashboards || {});

    XNAT.plugin.jupyterhub.dashboards = {
        url: '/xapi/jupyterhub/dashboards',
        get: async (id) => {
            const url = XNAT.url.csrfUrl(`${XNAT.plugin.jupyterhub.dashboards.url}/${id}`);

            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                return response.json();
            } else {
                throw new Error(`Failed to get dashboard with id ${id}`);
            }
        },
        getAll: async () => {
            const url = XNAT.url.csrfUrl(`${XNAT.plugin.jupyterhub.dashboards.url}`);

            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                return response.json();
            } else {
                throw new Error(`Failed to get dashboards`);
            }
        },
        create: async (dashboard) => {
            const url = XNAT.url.csrfUrl(`${XNAT.plugin.jupyterhub.dashboards.url}`);

            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(dashboard)
            });

            if (response.ok) {
                return response.json();
            } else {
                throw new Error(`Failed to create dashboard`);
            }
        },
        update: async (dashboard) => {
            const url = XNAT.url.csrfUrl(`${XNAT.plugin.jupyterhub.dashboards.url}/${dashboard.id}`);

            const response = await fetch(url, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(dashboard)
            });

            if (response.ok) {
                return response.json();
            } else {
                throw new Error(`Failed to update dashboard`);
            }
        },
        delete: async (id) => {
            const url = XNAT.url.csrfUrl(`${XNAT.plugin.jupyterhub.dashboards.url}/${id}`);

            const response = await fetch(url, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`Failed to delete dashboard with id ${id}`);
            }
        },
        editor: async (dashboard, action, onSaved) => {
            let isNew  = action === 'new',
                    isCopy = action === 'copy',
                    isEdit = action === 'edit',
                    title  = isNew || isCopy ? 'New Dashboard' : 'Edit Dashboard';

            XNAT.dialog.open({
                title: title,
                content: spawn('div.dashboard-editor'),
                width: 750,
                maxBtn: true,
                beforeShow: () => {
                    // Create form

                    const formContainer = document.querySelector(`.dashboard-editor`);
                    formContainer.classList.add('panel');

                    let id = isNew || isCopy ? '' : dashboard?.id ? dashboard?.id : '',
                            owner = dashboard?.owner ? dashboard?.owner : window.username,
                            name = dashboard?.name ? dashboard?.name : '',
                            description = dashboard?.description ? dashboard?.description : '',
                            version = dashboard?.version ? dashboard?.version : '',
                            framework = dashboard?.framework ? dashboard?.framework : '',
                            fileSource = dashboard?.fileSource ? dashboard?.fileSource : 'git-repo',
                            workspacePath = dashboard?.workspacePath ? dashboard?.workspacePath : '',
                            gitRepoUrl = dashboard?.gitRepoUrl ? dashboard?.gitRepoUrl : '',
                            gitRepoBranch = dashboard?.gitRepoBranch ? dashboard?.gitRepoBranch : '',
                            gitRepoTag = dashboard?.gitRepoTag ? dashboard?.gitRepoTag : '',
                            computeEnvironment = dashboard?.computeEnvironment ? dashboard?.computeEnvironment : '',
                            hardware = dashboard?.hardware ? dashboard?.hardware : '',
                            isPublic = dashboard?.isPublic ? dashboard?.isPublic : false,
                            isEnabled = dashboard?.isEnabled ? dashboard?.isEnabled : false;

                    let form = spawn('form.dashboard-edit-form', [
                        spawn('input#id', { type: 'hidden', value: id }),
                        spawn('input#owner', { type: 'hidden', value: owner }),
                        spawn('div.form-group', [
                            spawn('label', { for: 'name' }, 'Name'),
                            spawn('input#name.form-control', { type: 'text', value: name, placeholder: 'Enter dashboard name' })
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'description' }, 'Description'),
                            spawn('textarea#description.form-control', { value: description, placeholder: 'Enter dashboard description', style: { fontFamily: 'sans-serif' } }),
                            spawn('p.form-description', [
                                spawn('small', 'Optional')
                            ])
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'version' }, 'Version'),
                            spawn('input#version.form-control', { type: 'text', value: version, placeholder: '' }),
                            spawn('p.form-description', [
                                spawn('small', 'Optional')
                            ])
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'framework' }, 'Framework'),
                            spawn('select#framework.form-control', [
                                spawn('option', { value: '', disabled: true, selected: true }, 'Select dashboard framework'),
                                spawn('option', { value: 'Voila', selected: framework.toLowerCase() === 'voila' }, 'Voila'),
                                spawn('option', { value: 'Dash', selected: framework.toLowerCase() === 'dash' }, 'Dash'),
                                spawn('option', { value: 'Streamlit', selected: framework.toLowerCase() === 'streamlit' }, 'Streamlit'),
                                spawn('option', { value: 'Panel', selected: framework.toLowerCase() === 'panel' }, 'Panel'),
                                spawn('option', { value: 'Custom', selected: framework.toLowerCase() === 'custom' }, 'Custom')
                            ])
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'file-source' }, 'Source'),
                            spawn('div', [
                                spawn('input#user-workspace', { type: 'radio', name: 'file-source', value: 'user-workspace', checked: fileSource === 'user-workspace' }),
                                spawn('label', { for: 'user-workspace' }, 'User Workspace')
                            ]),
                            spawn('div', [
                                spawn('input#git-repo', { type: 'radio', name: 'file-source', value: 'git-repo', checked: fileSource === 'git-repo' }),
                                spawn('label', { for: 'git-repo' }, 'Git Repo')
                            ])
                        ]),
                        spawn('div.form-group.workspace', [
                            spawn('label', { for: 'workspace-path' }, 'Relative path to a file or directory'),
                            spawn('div.input-group', [
                                spawn('span.input-group-addon', { id: 'workspace-path' }, '/workspace/$user.getUsername()/'),
                                spawn('input#workspace-path.form-control', { type: 'text', value: workspacePath })
                            ]),
                            spawn('p.form-description', [
                                spawn('small', 'Relative to the root of your Jupyter workspace')
                            ])
                        ]),
                        spawn('div#git-repo.form-group.git', [
                            spawn('label', { for: 'git-repo-url' }, 'Git Repo URL'),
                            spawn('input#git-repo-url.form-control', { type: 'text', value: gitRepoUrl, placeholder: '' })
                        ]),
                        spawn('div.form-group.git', [
                            spawn('label', { for: 'git-repo-branch' }, 'Branch'),
                            spawn('input#git-repo-branch.form-control', { type: 'text', value: gitRepoBranch, placeholder: '' })
                        ]),
                        spawn('div.form-group.git', [
                            spawn('label', { for: 'git-repo-tag' }, 'Tag'),
                            spawn('input#git-repo-tag.form-control', { type: 'text', value: gitRepoTag, placeholder: '' })
                        ]),
                        spawn('div.form-group.git', [
                            spawn('label', { for: 'git-repo-path' }, 'Relative path to a file or directory'),
                            spawn('input#git-repo-tag.form-control', { type: 'text', value: gitRepoTag, placeholder: '' }),
                            spawn('p.form-description', [
                                spawn('small', 'Relative to the root of your Git repo')
                            ])
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'is-public' }, 'Accessibility'),
                            spawn('div', [
                                spawn('input#is-public', { type: 'radio', name: 'is-public', value: 'true', checked: isPublic }),
                                spawn('label', { for: 'is-public' }, 'Public')
                            ]),
                            spawn('div', [
                                spawn('input#is-public', { type: 'radio', name: 'is-public', value: 'false', checked: !isPublic }),
                                spawn('label', { for: 'is-public' }, 'Private')
                            ])
                        ]),
                        spawn('hr'),
                        spawn('div.form-group', [
                            spawn('label', { for: 'jupyter-environment' }, 'Jupyter Environment'),
                            spawn('select#jupyter-environment.form-control', [
                                spawn('option', { value: '', disabled: true, selected: true }, 'Select Jupyter environment')
                            ])
                        ]),
                        spawn('div.form-group', [
                            spawn('label', { for: 'hardware' }, 'Hardware'),
                            spawn('select#hardware.form-control', [
                                spawn('option', { value: '', disabled: true, selected: true }, 'Select hardware')
                            ])
                        ])
                    ]);

                    formContainer.appendChild(form);

                    // Handle file source
                    const displayUserWorkspaceElements = () => document.querySelectorAll('.workspace').forEach(element => element.style.display = '');
                    const hideUserWorkspaceElements =    () => document.querySelectorAll('.workspace').forEach(element => element.style.display = 'none');

                    const displayGitRepoElements = () => document.querySelectorAll('.git').forEach(element => element.style.display = '');
                    const hideGitRepoElements =    () => document.querySelectorAll('.git').forEach(element => element.style.display = 'none');

                    const fileSources = Array.from(document.querySelectorAll('input[name="file-source"]'))

                    fileSources.forEach(fileSource => {
                        fileSource.addEventListener('change', event => {
                            if (event.target.value === 'user-workspace') {
                                displayUserWorkspaceElements();
                                hideGitRepoElements();
                            } else {
                                displayGitRepoElements();
                                hideUserWorkspaceElements();
                            }
                        })
                    })

                    if (fileSource === 'user-workspace') {
                        displayUserWorkspaceElements();
                        hideGitRepoElements();
                    } else if (fileSource === 'git-repo') {
                        displayGitRepoElements();
                        hideUserWorkspaceElements();
                    }

                    // Handle Jupyter Environments and Hardware
                    let computeEnvironments = document.querySelector('#jupyter-environment');
                    let hardwares = document.querySelector('#hardware');

                    let computeEnvironmentConfigs;

                    XNAT.compute.computeEnvironmentConfigs.available("JUPYTERHUB").then((data) => {
                        computeEnvironmentConfigs = data;
                        data.forEach((environment) => {
                            let option = document.createElement('option');
                            option.value = environment.computeEnvironment.name;
                            option.text = environment.computeEnvironment.name;
                            computeEnvironments.add(option);
                        })
                    });

                    computeEnvironments.addEventListener('change', () => {
                        hardwares.innerHTML = '';
                        hardwares.appendChild(spawn('option', {value: ''}, 'Select hardware'));
                        let computeEnvironmentConfig = computeEnvironmentConfigs.filter(c => c['computeEnvironment']['name'].toString() === computeEnvironments.value)[0];
                        let hardwareConfigs = computeEnvironmentConfig['hardwareOptions']['hardwareConfigs'];
                        hardwareConfigs.forEach(h => {
                            hardwares.appendChild(spawn('option', {value: h['id']}, h['hardware']['name']));
                        });
                    });
                },
                buttons: [
                    {
                        label: 'Cancel',
                        isDefault: false,
                        close: false,
                        action: function () {
                            XNAT.dialog.closeAll();
                        }
                    },
                    {
                        label: 'Save',
                        isDefault: true,
                        close: false,
                        action: function (obj) {
                            let form = document.querySelector('.dashboard-edit-form');

                            const validators = [];

                            validators.push(
                                    XNAT.validate(form.querySelector('#name'))
                                            .reset().chain()
                                            .required()
                                            .is('notEmpty')
                                            .failure('Name is required')
                            );

                            let errorMessages = [];

                            validators.forEach((validator) => {
                                if (!validator.check()) {
                                    validator.messages.forEach(message => errorMessages.push(message));
                                }
                            });

                            if (errorMessages.length > 0) {
                                XNAT.dialog.open({
                                    title: 'Error',
                                    width: 400,
                                    content: '<ul><li>' + errorMessages.join('</li><li>') + '</li></ul>',
                                })
                                return;
                            }

                            (async () => {

                                const dashboard = {
                                    id: form.querySelector('#id').value,
                                    owner: form.querySelector('#owner').value,
                                    name: form.querySelector('#name').value,
                                    description: form.querySelector('#description').value,
                                    version: form.querySelector('#version').value,
                                    framework: form.querySelector('#framework').value,
                                    fileSource: form.querySelector('input[name="file-source"]:checked').value,
                                    workspacePath: form.querySelector('#workspace-path').value,
                                    gitRepoUrl: form.querySelector('#git-repo-url').value,
                                    gitRepoBranch: form.querySelector('#git-repo-branch').value,
                                    gitRepoTag: form.querySelector('#git-repo-tag').value,
                                    computeEnvironment: form.querySelector('#jupyter-environment').value,
                                    hardware: form.querySelector('#hardware').value,
                                    isPublic: form.querySelector('input[name="is-public"]:checked').value === 'true',
                                    isEnabled: true
                                };

                                let response;
                                if (isNew || isCopy) {
                                    response = XNAT.plugin.jupyterhub.dashboards.create(dashboard);
                                } else if (isEdit) {
                                    response = XNAT.plugin.jupyterhub.dashboards.update(dashboard);
                                }

                                response.then(() => {
                                    XNAT.ui.banner.top(2000, 'success', 'Dashboard saved.');
                                    obj.close();
                                    if (onSaved) {
                                        onSaved();
                                    }
                                }).catch((error) => {
                                    XNAT.ui.banner.top(2000, 'error', 'Failed to save dashboard');
                                    console.error(error);
                                });
                            })();
                        }
                    }
                ]
            })
        },
        table: async (querySelector) => {
            let container;

            const init = (querySelector) => {
                container = document.querySelector(querySelector);
                container.innerHTML = '<div class="table-container"><div class="loading"><i class="fa fa-spinner fa-spin"></i> Loading...</div></div>'

                container.style.display = 'flex';
                container.style.flexDirection = 'row';
                container.style.justifyContent = 'center';

                refresh();
            }

            const clear = () => {
                container.innerHTML = '';
            }

            const refresh = async () => {
                const dashboards = await XNAT.plugin.jupyterhub.dashboards.getAll();

                clear();

                if (dashboards.length === 0) {
                    container.innerHTML = `<div class="loading">No dashboards found</div>`;
                } else {
                    return table(dashboards);
                }
            }

            const remove = async (id) => {
                XNAT.dialog.open({
                    title: 'Confirm',
                    content: 'Are you sure you want to delete this dashboard?',
                    width: 400,
                    buttons: [
                        {
                            label: 'Cancel',
                            isDefault: false,
                            close: false,
                            action: function () {
                                XNAT.dialog.closeAll();
                            }
                        },
                        {
                            label: 'Delete',
                            isDefault: true,
                            close: false,
                            action: function (obj) {
                                XNAT.plugin.jupyterhub.dashboards.delete(id).then(() => {
                                    XNAT.ui.banner.top(2000, 'Dashboard deleted.', 'success');
                                    refresh();
                                    XNAT.dialog.closeAll();
                                }).catch((error) => {
                                    XNAT.ui.banner.top(2000, 'Failed to delete dashboard', 'error',);
                                    console.error(error);
                                });
                            }
                        }
                    ]
                })
            }

            const table = async (dashboards) => {
                const table = XNAT.table.dataTable(dashboards, {
                    header: true,
                    sortable: 'name, version, framework, fileSource, computeEnvironment, hardware, isPublic, isEnabled',
                    columns: {
                        name: {
                            label: 'Name',
                            th: { className: 'left' },
                        },
                        version: {
                            label: 'Version',
                            th: { style: { width: '100px' } },
                            apply: function () {
                                return spawn('div.center', [
                                    spawn('span', {}, this['version'] ? this['version'] : '')
                                ]);
                            }
                        },
                        framework: {
                            label: 'Framework',
                            th: { style: { width: '100px' } },
                            apply: function () {
                                return spawn('div.center', [
                                    spawn('span', {}, this['framework'] ? this['framework'] : '')
                                ]);
                            }
                        },
                        fileSource: {
                            label: 'Source',
                            th: { style: { width: '100px' } },
                            action: function () {
                                return spawn('div.center', [
                                    spawn('span', {}, this['fileSource'] === 'user-workspace' ? 'User Workspace' :
                                                      this['fileSource'] === 'git-repo' ? 'Git Repo' : '')
                                ]);
                            }
                        },
                        isPublic: {
                            label: 'Public',
                            th: { style: { width: '50px' } },
                            apply: function() {
                                return spawn('div.center', [
                                    spawn('span', {}, this['isPublic'] ? '<i class="fa fa-check"></i>' : '<i class="fa fa-ban"></i>')
                                ]);
                            }
                        },
                        isEnabled: {
                            label: 'Enabled',
                            th: { style: { width: '50px' } },
                            apply: function() {
                                return spawn('div.center', [
                                    spawn('span', {}, this['isEnabled'] ? '<i class="fa fa-check"></i>' : '<i class="fa fa-ban"></i>')
                                ]);
                            }
                        },
                        actions: {
                            label: 'Actions',
                            th: { style: { width: '150px' } },
                            apply: function() {
                                return spawn('div.center', [
                                    spawn('button.btn.btn-sm', { onclick: () => XNAT.plugin.jupyterhub.dashboards.editor(this, 'edit', refresh) }, '<i class="fa fa-pencil" title="Edit"></i>'),
                                    spawn('span', { style: { display: 'inline-block', width: '4px' } }),
                                    spawn('button.btn.btn-sm', { onclick: () => XNAT.plugin.jupyterhub.dashboards.editor(this, 'copy', refresh) }, '<i class="fa fa-clone" title="Duplicate"></i>'),
                                    spawn('span', { style: { display: 'inline-block', width: '4px' } }),
                                    spawn('button.btn.btn-sm', { onclick: () => remove(this['id'])}, '<i class="fa fa-trash" title="Delete"></i>')
                                ]);
                            }
                        }
                    }
                });

                clear()
                table.render(`${querySelector}`);
            }

            init(querySelector);

            return {
                init: init,
                refresh: refresh,
            }
        }
    }

    let dashboardManager = XNAT.plugin.jupyterhub.dashboards.table('#dashboard-manager .body');

</script>

